diff --git a/arch/sandbox/config.mk b/arch/sandbox/config.mk
index 275661a1..2f7c54b7 100644
--- a/arch/sandbox/config.mk
+++ b/arch/sandbox/config.mk
@@ -27,12 +27,14 @@ cmd_u-boot__ = \
 	$(CC) -o $@ -Wl,-T u-boot.lds $(u-boot-init) \
 	$(KBUILD_LDFLAGS:%=-Wl,%) \
 	$(SANITIZERS) \
+	$(KCFLAGS) \
