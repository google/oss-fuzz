# UEL (Universal Exit Language)
"\x1b%-12345X"

# PJL commands
"@PJL\x0d\x0a"
"@PJL ENTER LANGUAGE=PCL\x0d\x0a"
"@PJL SET RESOLUTION=600\x0d\x0a"
"@PJL SET COPIES=1\x0d\x0a"
