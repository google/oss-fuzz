+// Fuzz FillPredictRequestFromJson with arbitrary JSON strings to exercise
+// JSON-to-TensorProto conversion across all data types.
+void FuzzJsonPredict(const std::string &json_input) {
+  static const DataType dtypes[] = {DT_FLOAT, DT_DOUBLE, DT_INT32,
+                                     DT_INT64, DT_STRING, DT_BOOL};
+  for (DataType dt : dtypes) {
+    TensorInfoMap infomap;
+    TextFormat::ParseFromString(
+        absl::StrCat("dtype: ", DataType_Name(dt)), &infomap["default"]);
+
+    PredictRequest req;
+    JsonPredictRequestFormat format;
+    auto status = FillPredictRequestFromJson(json_input, getmap(infomap),
+                                             &req, &format);
+    (void)status;
+  }
+}
+FUZZ_TEST(JsonFuzzTest, FuzzJsonPredict);
+
+// Fuzz FillClassificationRequestFromJson with arbitrary JSON strings.
+void FuzzJsonClassify(const std::string &json_input) {
+  ClassificationRequest req;
+  auto status = FillClassificationRequestFromJson(json_input, &req);
+  (void)status;
+}
+FUZZ_TEST(JsonFuzzTest, FuzzJsonClassify);
+
+// Fuzz FillRegressionRequestFromJson with arbitrary JSON strings.
+void FuzzJsonRegress(const std::string &json_input) {
+  RegressionRequest req;
+  auto status = FillRegressionRequestFromJson(json_input, &req);
+  (void)status;
+}
+FUZZ_TEST(JsonFuzzTest, FuzzJsonRegress);
