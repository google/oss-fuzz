# WebSocket frame opcodes
opcode_continuation="\x00"
opcode_text="\x01"
opcode_binary="\x02"
opcode_close="\x08"
opcode_ping="\x09"
opcode_pong="\x0a"

# WebSocket headers (fin, rsv1-3, opcode)
header_text_fin="\x81"
header_binary_fin="\x82"

# Mask bit
mask_bit="\x80"

# Common lengths
len_126="\x7e"
len_127="\x7f"

# UUID for handshake
ws_uuid="258EAFA5-E914-47DA-95CA-C5AB0DC85B11"
